# ─── PriceHunt Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# The server starts without these set — MongoDB will fall back to in-memory.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/pricecompare
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pricecompare?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/pricecompare

# ── JWT ───────────────────────────────────────────────────────────────────────
# Replace with a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
